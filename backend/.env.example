# LLM Provider (openai, anthropic, or mock)
LLM_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database (SQLite for local dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./paperpulse.db

# App settings
APP_ENV=development
SECRET_KEY=change-me-in-production

# arXiv sync settings
ARXIV_MAX_RESULTS=50
SYNC_INTERVAL_HOURS=6
